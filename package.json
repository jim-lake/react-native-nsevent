{
  "name": "react-native-nsevent",
  "version": "0.0.1",
  "description": "React Native macOS native module for window-scoped NSEvent input with relative mouse capture",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "react-native": "src/index.ts",
  "source": "src/index.ts",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jim-lake/react-native-nsevent.git"
  },
  "codegenConfig": {
    "name": "RNNSEventSpec",
    "type": "modules",
    "jsSrcsDir": "spec"
  },
  "scripts": {
    "lint": "eslint . --fix",
    "pretty": "prettier --write \"src/**/*.ts\" \"spec/**/*.ts\" && clang-format -i macos/*.mm macos/*.h",
    "ts:check": "tsc --noEmit"
  },
  "keywords": [
    "react-native",
    "macos",
    "nsevent",
    "input",
    "mouse-capture"
  ],
  "license": "MIT",
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.71.0",
    "react-native-macos": ">=0.71.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "prettier": "^3.8.4",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.62.0"
  },
  "files": [
    "spec/",
    "src/",
    "macos/",
    "react-native-nsevent.podspec",
    "react-native.config.js"
  ]
}

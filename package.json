{
  "name": "react-native-nsevent",
  "version": "0.0.1",
  "description": "React Native macOS native module for window-scoped NSEvent input with relative mouse capture",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "react-native": "src/index.ts",
  "source": "src/index.ts",
  "type": "module",
  "codegenConfig": {
    "name": "RNNSEventSpec",
    "type": "modules",
    "jsSrcsDir": "src",
    "ios": {
      "moduleName": "RNNSEvent"
    },
    "macos": {
      "moduleName": "RNNSEvent"
    }
  },
  "scripts": {
    "pretty": "prettier --write \"src/**/*.ts\" \"__tests__/**/*.ts\" && clang-format -i macos/*.mm macos/*.h macos/*.cpp",
    "lint": "eslint src __tests__",
    "ts:check": "tsc --noEmit",
    "test:integration": "NODE_OPTIONS='--experimental-vm-modules' jest --config jest.integration.config.js"
  },
  "keywords": [
    "react-native",
    "macos",
    "nsevent",
    "input",
    "mouse-capture"
  ],
  "license": "MIT",
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-native": ">=0.71.0",
    "react-native-macos": ">=0.71.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/jest": "^29.5.0",
    "eslint": "^10.5.0",
    "jest": "^29.7.0",
    "prettier": "^3.8.4",
    "ts-jest": "^29.1.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.62.0",
    "webdriverio": "^8.27.0"
  },
  "files": [
    "src/",
    "macos/",
    "react-native-nsevent.podspec",
    "react-native.config.js"
  ]
}
